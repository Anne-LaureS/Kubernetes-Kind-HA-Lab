{
  "uid": "http_rps",
  "title": "HTTP RPS High",
  "folderUID": "general",
  "ruleGroup": "cluster-alerts",
  "interval": "160s",

  "condition": "C",

  "data": [
    {
      "refId": "A",
      "queryType": "timeSeriesQuery",
      "relativeTimeRange": { "from": 300, "to": 0 },
      "datasourceUid": "prometheus",
      "model": {
        "expr": "sum(rate(http_requests_total[5m]))",
        "refId": "A"
      }
    },
    {
      "refId": "C",
      "datasourceUid": "-100",
      "model": {
        "type": "threshold",
        "expression": "A",
        "thresholds": [
          { "value": 1000, "color": "red" }
        ]
      }
    }
  ],

  "for": "5m",
  "noDataState": "NoData",
  "execErrState": "Error",

  "labels": {
    "severity": "warning"
  },

  "annotations": {
    "summary": "HTTP RPS too high"
  }
}
